{
  "name": "changsha-mahjong-rule-engine",
  "version": "0.1.0",
  "description": "Changsha Mahjong Rule Engine in TypeScript",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc && vite build",
    "server": "tsc && node dist/changsha-mahjong-network/server/index.js",
    "dev:online": "concurrently \"npm run server\" \"vite --host 0.0.0.0 --port 5173\"",
    "dev:lan": "concurrently \"npm run server\" \"vite --host 0.0.0.0 --port 5173\""
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "typescript": "^5.4.5",
    "vite": "^8.1.1",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
